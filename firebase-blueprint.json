{
  "entities": {
    "listings": {
      "title": "Listing",
      "description": "A custom coffee blend listing",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "image_url": { "type": "string" },
        "user_id": { "type": "string" }
      },
      "required": ["title", "description", "price", "user_id"]
    },
    "orders": {
      "title": "Order",
      "description": "A coffee order",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "branch_id": { "type": "string" },
        "customer_name": { "type": "string" },
        "customer_phone": { "type": "string" },
        "items": { "type": "array" },
        "total_price": { "type": "number" },
        "status": { "type": "string" },
        "payment_method": { "type": "string" },
        "payment_type": { "type": "string" },
        "payable_amount": { "type": "number" },
        "transaction_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["customer_name", "customer_phone", "items", "total_price", "status"]
    },
    "admin_settings": {
      "title": "Admin Settings",
      "description": "Settings for a branch",
      "type": "object",
      "properties": {
        "branch_id": { "type": "string" },
        "password": { "type": "string" },
        "store_name": { "type": "string" },
        "store_email": { "type": "string" },
        "store_address": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["branch_id"]
    },
    "menu_availability": {
      "title": "Menu Availability",
      "description": "Availability of a menu item at a branch",
      "type": "object",
      "properties": {
        "branch_id": { "type": "string" },
        "item_id": { "type": "string" },
        "is_available": { "type": "boolean" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["branch_id", "item_id", "is_available"]
    }
  },
  "firestore": {
    "/listings/{listingId}": {
      "schema": "listings",
      "description": "Collection of custom coffee blends"
    },
    "/orders/{orderId}": {
      "schema": "orders",
      "description": "Collection of customer orders"
    },
    "/admin_settings/{settingId}": {
      "schema": "admin_settings",
      "description": "Settings for each branch"
    },
    "/menu_availability/{availabilityId}": {
      "schema": "menu_availability",
      "description": "Menu item availability per branch"
    }
  }
}
