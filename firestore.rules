rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: videos
    // Fields:
    //   - title: string (required)
    //   - creator: string (required)
    //   - creatorAvatar: string
    //   - embedUrl: string (required)
    //   - type: string (required)
    //   - views: string
    //   - postedAt: timestamp
    //   - authorUid: string (required, immutable)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(authorUid) {
      return isAuthenticated() && request.auth.uid == authorUid;
    }

    function isValidVideo(data) {
      return data.keys().hasAll(['title', 'creator', 'embedUrl', 'type']) &&
             data.keys().hasOnly(['title', 'creator', 'description', 'creatorAvatar', 'embedUrl', 'type', 'views', 'postedAt', 'authorUid']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.creator is string && data.creator.size() > 0 && data.creator.size() < 100 &&
             (!('description' in data) || (data.description is string && data.description.size() < 1000)) &&
             data.embedUrl is string && data.embedUrl.size() > 0 && data.embedUrl.size() < 2000 &&
             data.type in ['youtube', 'instagram', 'facebook', 'short', 'other'] &&
             (!('authorUid' in data) || (data.authorUid is string || data.authorUid == null)) &&
             (!('creatorAvatar' in data) || (data.creatorAvatar is string && data.creatorAvatar.size() < 1000)) &&
             (!('views' in data) || (data.views is string && data.views.size() < 50)) &&
             (!('postedAt' in data) || (data.postedAt is timestamp || data.postedAt == null));
    }

    match /videos/{videoId} {
      allow read: if true; // Anyone can view videos
      
      allow create: if isValidVideo(request.resource.data);
      
      allow update: if isAuthenticated() && 
                      isOwner(resource.data.authorUid) && 
                      isValidVideo(request.resource.data) &&
                      request.resource.data.authorUid == resource.data.authorUid;
                      
      allow delete: if isAuthenticated() && isOwner(resource.data.authorUid);
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || request.auth.token.email == "pikachiuchiha956@gmail.com");
      allow create: if true; // Allow anonymous checkout if needed, or check isAuthenticated()
      allow update: if isAuthenticated() && request.auth.token.email == "pikachiuchiha956@gmail.com";
    }

    match /admin_settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.token.email == "pikachiuchiha956@gmail.com";
    }

    match /menu_availability/{availabilityId} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.token.email == "pikachiuchiha956@gmail.com";
    }
  }
}
