rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: videos
    // Fields:
    //   - title: string (required)
    //   - creator: string (required)
    //   - creatorAvatar: string
    //   - embedUrl: string (required)
    //   - type: string (required)
    //   - views: string
    //   - postedAt: timestamp
    //   - authorUid: string (required, immutable)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(authorUid) {
      return isAuthenticated() && request.auth.uid == authorUid;
    }

    function isValidVideo(data) {
      return data.keys().hasAll(['title', 'creator', 'embedUrl', 'type', 'authorUid']) &&
             data.keys().hasOnly(['title', 'creator', 'creatorAvatar', 'embedUrl', 'type', 'views', 'postedAt', 'authorUid']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.creator is string && data.creator.size() > 0 && data.creator.size() < 100 &&
             data.embedUrl is string && data.embedUrl.size() > 0 && data.embedUrl.size() < 1000 &&
             data.type in ['youtube', 'instagram', 'facebook', 'short'] &&
             data.authorUid == request.auth.uid &&
             (!('creatorAvatar' in data) || (data.creatorAvatar is string && data.creatorAvatar.size() < 1000)) &&
             (!('views' in data) || (data.views is string && data.views.size() < 50)) &&
             (!('postedAt' in data) || (data.postedAt is timestamp));
    }

    match /videos/{videoId} {
      allow read: if true; // Anyone can view videos
      
      allow create: if isAuthenticated() && isValidVideo(request.resource.data);
      
      allow update: if isAuthenticated() && 
                      isOwner(resource.data.authorUid) && 
                      isValidVideo(request.resource.data) &&
                      request.resource.data.authorUid == resource.data.authorUid;
                      
      allow delete: if isAuthenticated() && isOwner(resource.data.authorUid);
    }
  }
}
