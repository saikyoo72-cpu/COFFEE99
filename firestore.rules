rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(authorUid) {
      return isAuthenticated() && request.auth.uid == authorUid;
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.user_id == request.auth.uid;
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource.data.user_id == request.auth.uid || request.auth.token.email == "pikachiuchiha956@gmail.com");
      allow create: if true; // Allow anonymous checkout if needed, or check isAuthenticated()
      allow update: if isAuthenticated() && request.auth.token.email == "pikachiuchiha956@gmail.com";
    }

    match /admin_settings/{settingId} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.token.email == "pikachiuchiha956@gmail.com";
    }

    match /menu_availability/{availabilityId} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.token.email == "pikachiuchiha956@gmail.com";
    }
  }
}
